{
  "name": "@mcptoolshop/brand",
  "version": "1.0.6",
  "description": "Centralized brand asset management — migration, audit, and integrity verification for GitHub orgs",
  "type": "module",
  "bin": {
    "brand": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "keywords": [
    "brand",
    "assets",
    "logo",
    "integrity",
    "sha256",
    "migration",
    "github",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/brand.git"
  },
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/brand/issues"
  },
  "homepage": "https://mcp-tool-shop-org.github.io/brand/",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fast": "vitest run --exclude tests/manifest-cmd.test.ts --exclude tests/verify.test.ts --exclude tests/json-output.test.ts --exclude tests/exit-codes.test.ts",
    "test:slow": "vitest run tests/manifest-cmd.test.ts tests/verify.test.ts tests/json-output.test.ts tests/exit-codes.test.ts",
    "test:ci": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "mcp-tool-shop",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
