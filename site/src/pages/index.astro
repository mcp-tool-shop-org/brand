---
import '../styles/global.css';
import BaseLayout from '@mcptoolshop/site-theme/components/BaseLayout.astro';
import Hero from '@mcptoolshop/site-theme/components/Hero.astro';
import Section from '@mcptoolshop/site-theme/components/Section.astro';
import FeatureGrid from '@mcptoolshop/site-theme/components/FeatureGrid.astro';
import DataTable from '@mcptoolshop/site-theme/components/DataTable.astro';
import CodeCardGrid from '@mcptoolshop/site-theme/components/CodeCardGrid.astro';
import ApiList from '@mcptoolshop/site-theme/components/ApiList.astro';
import { config } from '../site-config';
---

<BaseLayout
  title={config.title}
  description={config.description}
  logoBadge={config.logoBadge}
  brandName={config.brandName}
  repoUrl={config.repoUrl}
  npmUrl={config.npmUrl}
  footerText={config.footerText}
  nav={config.sections.map(s => ({ href: `#${s.id}`, label: s.title }))}
>
  <Hero {...config.hero} />

  {config.sections.map((s) => {
    // Exhaustive section renderer. The `_exhaustive: never` assignment in
    // the default branch is a TypeScript exhaustiveness check — if a new
    // section kind is added to site-theme's union and not handled here,
    // tsc + astro check will fail. At runtime, an unknown kind throws
    // loud instead of silently rendering an empty Section body.
    let body;
    if (s.kind === 'features') {
      body = <FeatureGrid features={s.features} />;
    } else if (s.kind === 'data-table') {
      body = <DataTable columns={s.columns} rows={s.rows} />;
    } else if (s.kind === 'code-cards') {
      body = <CodeCardGrid cards={s.cards} />;
    } else if (s.kind === 'api') {
      body = <ApiList apis={s.apis} />;
    } else {
      // Exhaustiveness check — if this line ever fails to type-check, a new
      // section kind was added to site-theme without being handled above.
      const _exhaustive: never = s;
      void _exhaustive;
      throw new Error(`Unknown section kind: ${(s as { kind: string }).kind}`);
    }
    return (
      <Section id={s.id} title={s.title} subtitle={s.subtitle}>
        {body}
      </Section>
    );
  })}
</BaseLayout>
